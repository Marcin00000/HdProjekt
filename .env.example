# =============================================================================
# Azure Data Lake (Storage Account z włączonym hierarchical namespace)
# Portal: Storage Account → Access keys
# =============================================================================
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER=job-data

AZURE_LAKE_RAW_PATH=raw/job_salary_prediction_dataset.csv
AZURE_LAKE_SILVER_PATH=silver/cleaned.parquet
AZURE_LAKE_GOLD_PATH=gold/salary_by_location.parquet

AZURE_DVC_CONTAINER=dvc-artifacts

# =============================================================================
# Azure SQL Database (hurtownia)
# Wymagany lokalnie: ODBC Driver 18 for SQL Server
# =============================================================================
AZURE_SQL_SERVER=twoj-serwer.database.windows.net
AZURE_SQL_DATABASE=job-salary-dwh
AZURE_SQL_USER=sqladmin
AZURE_SQL_PASSWORD=

# Opcjonalnie: pełny URI SQLAlchemy (nadpisuje pola powyżej)
# AZURE_SQL_CONNECTION_STRING=mssql+pyodbc://...

# =============================================================================
# Dane lokalne (przed uploadem do raw/)
# =============================================================================
LOCAL_RAW_DATA_PATH=job_salary_prediction_dataset.csv

# =============================================================================
# Kaggle (opcjonalnie)
# =============================================================================
KAGGLE_USERNAME=
KAGGLE_KEY=

# =============================================================================
# MLflow
# =============================================================================
MLFLOW_TRACKING_URI=file:./mlruns
